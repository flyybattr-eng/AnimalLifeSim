#include "PrimalGameData_ModDrive_BP.h"

void UPrimalGameData_ModDrive_BP::InitAllDinosDynamicArray()
{
    UClass* ClassMaster = APrimalDinoCharacter::StaticClass();
    TArray<UClass*> Array_AllDinosClasses = UGameplayStatics::GetEngineSubclasses(ClassMaster);

    for (UClass* CurrentClass : Array_AllDinosClasses)
    {
        if (CurrentClass && CurrentClass->GetDefaultObject<APrimalDinoCharacter>()->DinoNameTag != "")
        {
            Widget_Menu->ScrollBox_Dinos->AddChild(CreateWidget(PlayerController, UI_DinoButton_Widget, CurrentClass));
        }
    }
}

void UPrimalGameData_ModDrive_BP::OnDinoSelected(UClass* TargetDinoClass)
{
    FVector SpawnLoc = PlayerHumanCharacter->GetActorLocation();
    FRotator SpawnRot = PlayerHumanCharacter->GetActorRotation();

    PlayerHumanCharacter->SetActorHiddenInGame(true);
    PlayerHumanCharacter->SetActorEnableCollision(false);
    PlayerHumanCharacter->bIsInvulnerable = true;

    APrimalDinoCharacter* NewDinoPawn = GetWorld()->SpawnActor<APrimalDinoCharacter>(TargetDinoClass, SpawnLoc, SpawnRot);
    PlayerController->Possess(NewDinoPawn);

    CurrentControlledDino = NewDinoPawn;
    InitializeFirstPersonCamera(CurrentControlledDino);
}
#include "UI_DinoCustomizer_Widget.h"

void UUI_DinoCustomizer_Widget::OnMouseScrollUp()
{
    UCameraComponent* CameraComponent = CurrentControlledDino->FindComponentByClass<UCameraComponent>();
    USpringArmComponent* SpringArmComponent = CurrentControlledDino->FindComponentByClass<USpringArmComponent>();

    if (SpringArmComponent->TargetArmLength > 0.0f)
    {
        SpringArmComponent->TargetArmLength -= 30.0f;
        if (SpringArmComponent->TargetArmLength <= 0.0f)
        {
            SpringArmComponent->TargetArmLength = 0.0f;
            SpringArmComponent->bUsePawnControlRotation = true;
            CameraComponent->AttachToComponent(CurrentControlledDino->GetMesh(), FAttachmentTransformRules::SnapToTargetIncludingScale, "head");
            bIsFirstPersonView = true;
        }
    }
}

void UUI_DinoCustomizer_Widget::OnMouseScrollDown()
{
    UCameraComponent* CameraComponent = CurrentControlledDino->FindComponentByClass<UCameraComponent>();
    USpringArmComponent* SpringArmComponent = CurrentControlledDino->FindComponentByClass<USpringArmComponent>();

    if (bIsFirstPersonView)
    {
        CameraComponent->AttachToComponent(SpringArmComponent, FAttachmentTransformRules::KeepRelativeTransform);
        bIsFirstPersonView = false;
    }

    if (SpringArmComponent->TargetArmLength < 400.0f)
    {
        SpringArmComponent->TargetArmLength += 30.0f;
    }
}
#include "UI_DinoCustomizer_Widget.h"

void UUI_DinoCustomizer_Widget::OnSliderMoved_HeadScale(float SliderValue)
{
